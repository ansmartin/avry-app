CREATE TABLE users(
    username TEXT PRIMARY KEY
)

CREATE TABLE games(
	username TEXT NOT NULL,
    gamename TEXT NOT NULL,
	rolls INTEGER NOT NULL,
	used_rolls INTEGER NOT NULL,
	tickets INTEGER NOT NULL,
	money INTEGER NOT NULL,
	item_points INTEGER NOT NULL,
	generation INTEGER NOT NULL,
	include_mythical BOOLEAN NOT NULL,
	include_legendary BOOLEAN NOT NULL,
	include_sublegendary BOOLEAN NOT NULL,
	include_powerhouse BOOLEAN NOT NULL,
	include_others BOOLEAN NOT NULL,
	fully_evolved_only BOOLEAN NOT NULL,
	FOREIGN KEY (username) REFERENCES users(username),
	CONSTRAINT game_pk PRIMARY KEY (username, gamename)
)

CREATE TABLE pokemon_box(
	username TEXT NOT NULL,
    gamename TEXT NOT NULL,
	pokemon_id INTEGER NOT NULL,
	FOREIGN KEY (username) REFERENCES games(username),
	FOREIGN KEY (gamename) REFERENCES games(gamename),
	CONSTRAINT roll_pk PRIMARY KEY (username, gamename, pokemon_id)
)

CREATE TABLE used_cards(
	username TEXT NOT NULL,
    gamename TEXT NOT NULL,
	card_id INTEGER NOT NULL,
	FOREIGN KEY (username) REFERENCES games(username),
	FOREIGN KEY (gamename) REFERENCES games(gamename),
	CONSTRAINT used_card_pk PRIMARY KEY (username, gamename, card_id)
)
